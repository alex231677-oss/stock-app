/* ════════ READER ════════ */
function setMode(m){
  readerMode=m;
  ['url','text','img','video'].forEach(id=>{
    document.getElementById('mc-'+id).classList.toggle('active',id===m);
    document.getElementById('rp-'+id).style.display=id===m?'':'none';
  });
}
function handleImgUpload(e){
  const f=e.target.files[0];if(!f)return;
  const r=new FileReader();
  r.onload=ev=>{imgB64=ev.target.result.split(',')[1];const p=document.getElementById('imgPreview');p.src=ev.target.result;p.style.display='block';document.getElementById('uploadZone').style.display='none';};
  r.readAsDataURL(f);
}
function handleDrop(e){
  e.preventDefault();document.getElementById('uploadZone').classList.remove('drag');
  const f=e.dataTransfer.files[0];if(f&&f.type.startsWith('image/')){const fe={target:{files:[f]}};handleImgUpload(fe);}
}
function getReaderInput(){
  if(readerMode==='url')return{type:'url',content:document.getElementById('urlInput').value.trim()};
  if(readerMode==='text')return{type:'text',content:document.getElementById('textInput').value.trim()};
  if(readerMode==='img')return{type:'img',content:imgB64,caption:document.getElementById('imgCaption').value.trim()};
  if(readerMode==='video')return{type:'video',content:document.getElementById('videoInput').value.trim()};
}
async function startReader(){
  const inp=getReaderInput();
  if(!inp.content){alert('請先輸入分析內容！');return;}
  const key=getKey();
  document.getElementById('readerBtn').disabled=true;
  document.getElementById('readerLoading').style.display='block';
  document.getElementById('readerResult').innerHTML='';
  const steps=['讀取資料...','識別關鍵資訊...','分析技術訊號...','生成買賣建議...','撰寫完整報告...'];
  let prog=0;
  const pf=document.getElementById('progFill'),sl=document.getElementById('stepLbl');
  const timer=setInterval(()=>{prog=Math.min(prog+18,88);pf.style.width=prog+'%';sl.textContent=steps[Math.floor(prog/20)]||steps[4];},600);
  try{
    const result=key?await callReaderAI(inp,key):genDemoResult(inp);
    clearInterval(timer);pf.style.width='100%';sl.textContent='分析完成！';
    setTimeout(()=>{document.getElementById('readerLoading').style.display='none';renderReaderResult(result);if(document.getElementById('tog2').classList.contains('on'))saveHist(inp,result);},350);
  }catch(e){
    clearInterval(timer);document.getElementById('readerLoading').style.display='none';
    document.getElementById('readerResult').innerHTML=`<div style="background:var(--red-dim);border:1px solid var(--red-border);border-radius:var(--r);padding:14px;font-size:13px;color:var(--red)">❌ 分析失敗：${e.message}</div>`;
  }
  document.getElementById('readerBtn').disabled=false;
}
async function callReaderAI(inp,key){
  const focus=[...document.querySelectorAll('#focusTags .ftag.active')].map(b=>b.textContent.trim()).join('、');
  const sys=`你是專業台灣股市 AI 分析師。以嚴格 JSON 格式回覆，結構：{"signal":"buy"|"sell"|"watch"|"neutral","confidence":0-100,"signalTitle":"10字內","highlights":[{"tag":"positive"|"negative"|"neutral"|"data","text":"重點（可含<mark>關鍵詞</mark>）"}],"keyNumbers":[{"label":"名稱","value":"數值","trend":"up"|"down"|"neutral"}],"report":{"summary":"80字","technical":"80字","fundamental":"80字","risk":"60字","suggestion":"60字"}}。只回覆 JSON，無其他文字。`;
  let msgs=[];
  if(inp.type==='img'){msgs=[{role:'user',content:[{type:'image',source:{type:'base64',media_type:'image/jpeg',data:inp.content}},{type:'text',text:`分析此圖${inp.caption?'（'+inp.caption+'）':''}，重點：${focus}`}]}];}
  else{const t={url:`分析此網址資料：${inp.content}，重點：${focus}`,text:`分析以下內容，重點：${focus}\n\n${inp.content}`,video:`分析以下影片字幕，重點：${focus}\n\n${inp.content}`}[inp.type];msgs=[{role:'user',content:t}];}
  const model=inp.type==='img'?'claude-sonnet-4-6':'claude-haiku-4-5-20251001';
  const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model,max_tokens:1200,system:sys,messages:msgs})});
  const d=await r.json();
  if(!d.content)throw new Error(d.error?.message||'未知錯誤');
  return JSON.parse(d.content[0].text.replace(/```json|```/g,'').trim());
}
function genDemoResult(){
  return{signal:'buy',confidence:72,signalTitle:'偏多，建議分批布局',highlights:[{tag:'positive',text:'<mark>CoWoS 先進封裝</mark>訂單持續增加，AI 需求超出預期'},{tag:'data',text:'法人目標價上調至 <mark>1,200 元</mark>，上漲空間 <mark>11%</mark>'},{tag:'positive',text:'<mark>外資連三日</mark>買超，資金動能偏強'},{tag:'negative',text:'<mark>美中科技戰</mark>風險升溫，出口管制疑慮'},{tag:'neutral',text:'本季毛利率預估維持 <mark>53-55%</mark>，符合預期'},{tag:'negative',text:'RSI 接近<mark>超買區間</mark>，短線留意技術回調'}],keyNumbers:[{label:'目標價',value:'NT$1,200',trend:'up'},{label:'上漲空間',value:'+11.1%',trend:'up'},{label:'預估毛利率',value:'53~55%',trend:'neutral'},{label:'外資動向',value:'連3日買超',trend:'up'}],report:{summary:'整體訊號偏多，AI 伺服器需求帶動先進封裝業務強勁成長，法人調升目標價反映基本面改善。',technical:'RSI 62 偏強，MACD 黃金交叉，均線多頭排列。短線有拉回至支撐整理可能。',fundamental:'CoWoS 產能擴張，AI 晶片需求旺盛。本季營收有望創歷史新高。',risk:'美中科技戰升溫；台幣升值壓縮獲利；短線籌碼略顯擁擠。',suggestion:'⚠️ 示範結果，請設定 API Key 獲取真實分析。建議分批布局，停損設支撐下方 3-5%。'}};
}
function renderReaderResult(r){
  const area=document.getElementById('readerResult');
  const st={buy:'買入訊號',sell:'賣出訊號',watch:'觀察等待',neutral:'中性持有'}[r.signal];
  const hlHtml=r.highlights.map(h=>`<div class="hl-it"><span class="hl-tag ${h.tag}">${{positive:'利多',negative:'利空',neutral:'中性',data:'數據'}[h.tag]}</span><div class="hl-text">${h.text}</div></div>`).join('');
  const knHtml=r.keyNumbers.map(k=>`<div class="kn-it"><div class="kn-lbl">${k.label}</div><div class="kn-val ${k.trend==='up'?'up':k.trend==='down'?'down':''}">${k.value}</div></div>`).join('');
  area.innerHTML=`
  <div class="sig-card ${r.signal}">
    <div class="sig-hd"><span class="sig-badge">${st}</span><span class="sig-title">${r.signalTitle}</span><span class="sig-conf">信心 ${r.confidence}%</span></div>
    <div class="kn-grid">${knHtml}</div>
  </div>
  <div class="hl-wrap">
    <div class="hl-title">🔍 AI 圈出重點 <span style="font-size:10px;background:var(--bg4);padding:2px 6px;border-radius:4px;">${r.highlights.length} 項</span></div>
    ${hlHtml}
  </div>
  <div class="rpt-wrap">
    <div class="rpt-sec"><div class="rpt-lbl">整體摘要</div><div class="rpt-txt">${r.report.summary}</div></div>
    <div class="divider"></div>
    <div class="rpt-sec"><div class="rpt-lbl">技術面</div><div class="rpt-txt">${r.report.technical}</div></div>
    <div class="divider"></div>
    <div class="rpt-sec"><div class="rpt-lbl">基本面 / 消息面</div><div class="rpt-txt">${r.report.fundamental}</div></div>
    <div class="divider"></div>
    <div class="rpt-sec"><div class="rpt-lbl">⚠️ 風險提示</div><div class="rpt-txt" style="color:var(--red);">${r.report.risk}</div></div>
    <div class="divider"></div>
    <div class="rpt-sec"><div class="rpt-lbl">操作建議</div><div class="rpt-txt" style="color:var(--green);">${r.report.suggestion}</div></div>
  </div>
  <div style="font-size:10px;text-align:center;color:var(--text3);padding:6px 0;">⚠️ 以上分析僅供參考，不構成投資建議</div>`;
}

/* ════════ CHAT ════════ */
async function sendChat(){
  const inp=document.getElementById('chatInput'),msg=inp.value.trim();
  if(!msg)return; inp.value=''; inp.style.height='auto';
  appendBubble('u',msg); chatMsgs.push({role:'user',content:msg});
  await callChatAI();
}
function sendQ(m){document.getElementById('chatInput').value=m;sendChat();}
function appendBubble(role,text){
  const h=document.getElementById('chatHist');
  const d=document.createElement('div');
  d.className='bubble bubble-'+role; d.textContent=text;
  h.appendChild(d); h.scrollTop=h.scrollHeight; return d;
}
async function callChatAI(){
  const key=getKey(),typing=appendBubble('a','...');
  if(!key){typing.textContent='⚠️ 請在「更多」→「設定」輸入 API Key 後使用對話功能。';return;}
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:500,system:'你是專業台灣股市 AI 顧問，用繁體中文回覆，語氣專業親切，回答具體簡潔（不超過200字）。適時提醒投資風險。',messages:chatMsgs})});
    const d=await r.json();
    const reply=d.content?.[0]?.text||'回覆失敗';
    typing.textContent=reply; chatMsgs.push({role:'assistant',content:reply});
    document.getElementById('chatHist').scrollTop=999999;
  }catch(e){typing.textContent='連線失敗：'+e.message;}
}
function clearChat(){chatMsgs=[];document.getElementById('chatHist').innerHTML='<div class="bubble bubble-a">對話已清除。請問有什麼問題？</div>';}
function chatKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChat();}}
function autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,110)+'px';}

/* ════════ HISTORY ════════ */
function saveHist(inp,result){
  const labels={url:'網址',text:'文字',img:'圖片',video:'字幕'};
  analysisHist.unshift({id:Date.now(),mode:labels[inp.type],preview:inp.type==='img'?'（圖片分析）':(inp.content||'').slice(0,55)+'...',signal:result.signal,title:result.signalTitle,conf:result.confidence,time:new Date().toLocaleString('zh-TW'),result});
  if(analysisHist.length>30)analysisHist=analysisHist.slice(0,30);
  localStorage.setItem('aHist',JSON.stringify(analysisHist));
  document.getElementById('histDot').classList.add('show');
}
function renderHist(){
  document.getElementById('histDot').classList.remove('show');
  const el=document.getElementById('histList');
  if(!analysisHist.length){el.innerHTML='<div class="empty"><div class="ei">📂</div><p>尚無分析記錄<br>完成研讀後自動儲存</p></div>';return;}
  const sc={buy:'color:var(--green);background:var(--green-dim)',sell:'color:var(--red);background:var(--red-dim)',watch:'color:var(--gold);background:var(--gold-dim)',neutral:'color:var(--blue);background:var(--blue-dim)'};
  const st={buy:'買入',sell:'賣出',watch:'觀察',neutral:'中性'};
  el.innerHTML=analysisHist.map(h=>`<div class="hist-it" onclick="loadHist(${h.id})"><div class="hist-hd"><span class="hist-type">${h.mode}</span><span class="hist-time">${h.time}</span></div><div class="hist-ttl">${h.title}</div><div class="hist-prv">${h.preview}</div><span class="hist-sig" style="${sc[h.signal]}">${st[h.signal]} · 信心 ${h.conf}%</span></div>`).join('');
}
function loadHist(id){
  const h=analysisHist.find(x=>x.id==id);if(!h)return;
  switchTab('reader',document.querySelectorAll('.tab')[1]);
  renderReaderResult(h.result);
  document.getElementById('readerResult').scrollIntoView({behavior:'smooth'});
}
function clearHist(){if(!confirm('確定清除所有記錄？'))return;analysisHist=[];localStorage.removeItem('aHist');renderHist();}

renderNews();
