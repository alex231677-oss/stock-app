  </div>`;
  document.getElementById('analyzeResult').innerHTML=html;
  document.getElementById('analyzeResult').style.display='block';
  drawChart(s);
  if(document.getElementById('tog1').classList.contains('on')) runStockAI();
}

function drawChart(s){
  const ctx=document.getElementById('priceChart').getContext('2d');
  if(chartInst) chartInst.destroy();
  const n=5,labels=[],data=[];
  for(let i=0;i<n;i++){const d=new Date();d.setDate(d.getDate()-(n-1-i));labels.push((d.getMonth()+1)+'/'+(d.getDate()));const f=s.trend==='up'?(0.92+i*.02+Math.random()*.01):(1.06-i*.02-Math.random()*.01);data.push(Math.round(s.price*f));}
  data[n-1]=s.price;
  const c=s.trend==='up'?'#2dce6e':'#ff5a5a';
  chartInst=new Chart(ctx,{type:'line',data:{labels,datasets:[{data,borderColor:c,backgroundColor:c.replace(')',',0.1)').replace('rgb','rgba').replace('#2dce6e','rgba(45,206,110,0.1)').replace('#ff5a5a','rgba(255,90,90,0.1)'),borderWidth:2,fill:true,tension:.4,pointRadius:3,pointBackgroundColor:c}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:'#1a2236'},ticks:{color:'#566880',font:{size:10}}},y:{grid:{color:'#1a2236'},ticks:{color:'#566880',font:{size:10}}}}}});
}
function setPrd(btn){document.querySelectorAll('.prd').forEach(b=>b.classList.remove('active'));btn.classList.add('active');if(curStock)drawChart(curStock);}

async function runStockAI(){
  const s=curStock; if(!s)return;
  const el=document.getElementById('aiAnalyzeResult');
  el.innerHTML='<div class="ai-typing"><span></span><span></span><span></span></div>';
  const key=getKey();
  const prompt=`請用繁體中文分析以下台股資料，給出約150字的走勢判讀：\n股票：${s.name}（${s.code}）現價：${s.price}元 漲跌：${s.change>0?'+':''}${s.change}(${s.pct}%)\nRSI:${s.rsi} MACD:${s.macd} MA5/20:${s.ma} KD:${s.kd} 成交量:${s.vol}\n信號強度:${s.sig}%\n請包含：①目前趨勢 ②關鍵支撐壓力 ③短線操作建議 ④風險提示`;
  if(!key){el.innerHTML=`<div class="ai-text">⚠️ 尚未設定 API Key，請至「更多」→「設定」輸入。\n\n📊 技術摘要：\n• RSI ${s.rsi}：${s.rsi>70?'超買，留意回調':s.rsi<30?'超賣，可能反彈':'中性偏多'}\n• MACD：${s.macd[0]==='+'?'黃金交叉，多頭訊號':'死亡交叉，空頭訊號'}\n• 綜合信號 ${s.sig}%：${s.sig>=60?'偏多':s.sig<=40?'偏空':'中性'}</div>`;return;}
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:400,messages:[{role:'user',content:prompt}]})});
    const d=await r.json();
    el.innerHTML=`<div class="ai-text">${d.content?.[0]?.text||'分析失敗'}</div>`;
  }catch(e){el.innerHTML=`<div class="ai-text" style="color:var(--red)">連線失敗：${e.message}</div>`;}
}

function sendToReader(){
  if(!curStock)return;
  const info=`【${curStock.name} (${curStock.code}) 技術分析資料】\n現價：${curStock.price} 元\n今日漲跌：${curStock.change>0?'+':''}${curStock.change} (${curStock.pct}%)\nRSI(14)：${curStock.rsi}\nMACD：${curStock.macd}\nMA5/MA20：${curStock.ma}\nKD：${curStock.kd}\n成交量：${curStock.vol}\n週轉率：${curStock.turn}\n本益比：${curStock.pe}\n殖利率：${curStock.yld}\n市值：${curStock.mkt}`;
  setMode('text');
  document.getElementById('textInput').value=info;
  switchTab('reader',document.querySelectorAll('.tab')[1]);
}

/* ════════ WATCHLIST ════════ */
function addWL(){
  if(!curStock)return;
  if(watchlist.find(w=>w.code===curStock.code)){alert('已在自選股清單');return;}
  watchlist.push({...curStock});
  localStorage.setItem('wl',JSON.stringify(watchlist));
  renderWatchlist(); alert('已加入：'+curStock.name);
}
function removeWL(code){watchlist=watchlist.filter(w=>w.code!==code);localStorage.setItem('wl',JSON.stringify(watchlist));renderWatchlist();}
function renderWatchlist(){
  const c=document.getElementById('wlContainer'),s=document.getElementById('wlSummary');
  if(!watchlist.length){c.innerHTML='<div class="empty"><div class="ei">⭐</div><p>尚未新增自選股</p></div>';s.style.display='none';return;}
  s.style.display='block';
  let ups=0,dns=0,tot=0;
  c.innerHTML=watchlist.map(w=>{
    const up=w.change>=0; if(up)ups++;else dns++; tot+=w.pct;
    return`<div class="wl-item"><div class="wl-l"><div class="wl-code">${w.code} ${w.name}</div><div class="wl-nm">${w.sector}</div></div><div class="wl-r"><div><div class="wl-price ${up?'up':'down'}">${w.price.toLocaleString()}</div><div class="wl-chg ${up?'up':'down'}">${up?'▲ +':'▼ '}${w.pct}%</div></div><button class="wl-del" onclick="removeWL('${w.code}')">✕</button></div></div>`;
  }).join('');
  document.getElementById('wl-cnt').textContent=watchlist.length;
  const avg=(tot/watchlist.length).toFixed(2);
  document.getElementById('wl-avg').textContent=avg+'%';
  document.getElementById('wl-avg').className='sum-v '+(tot>=0?'up':'down');
  document.getElementById('wl-up').textContent=ups;
  document.getElementById('wl-dn').textContent=dns;
}

