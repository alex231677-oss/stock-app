<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="台股AI">
<title>台股 AI 完整助理</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap');
:root {
  --bg:#0b0f1a; --bg2:#111827; --bg3:#1a2236; --bg4:#222d42;
  --border:#2a3650; --border2:#3a4d6a;
  --text:#e8eef8; --text2:#8fa3c0; --text3:#566880;
  --green:#2dce6e; --green-dim:rgba(45,206,110,0.12); --green-border:rgba(45,206,110,0.3);
  --red:#ff5a5a; --red-dim:rgba(255,90,90,0.12); --red-border:rgba(255,90,90,0.3);
  --blue:#4d9fff; --blue-dim:rgba(77,159,255,0.12); --blue-border:rgba(77,159,255,0.3);
  --gold:#f5c842; --gold-dim:rgba(245,200,66,0.12); --gold-border:rgba(245,200,66,0.3);
  --purple:#a78bfa; --purple-dim:rgba(167,139,250,0.12);
  --accent:#4d9fff; --accent2:#2dce6e;
  --r:10px; --r2:14px; --tab-h:60px; --hd-h:58px;
  --font:'Noto Sans TC',-apple-system,'PingFang TC',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;overscroll-behavior:none;}
body{font-family:var(--font);background:var(--bg);color:var(--text);max-width:480px;margin:0 auto;position:relative;overflow-x:hidden;}

/* ── HEADER ── */
.hd{position:sticky;top:0;z-index:200;height:var(--hd-h);background:rgba(11,15,26,0.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 14px;}
.hd-left{display:flex;align-items:center;gap:10px;}
.hd-logo{width:32px;height:32px;border-radius:9px;background:linear-gradient(135deg,#1a6bff,#2dce6e);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.hd-name{font-size:16px;font-weight:700;letter-spacing:-.3px;}
.hd-sub{font-size:10px;color:var(--text3);margin-top:1px;}
.mkt-badge{font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;border:1px solid;}

/* ── TABS ── */
.tabs{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;height:var(--tab-h);background:rgba(11,15,26,0.97);backdrop-filter:blur(16px);border-top:1px solid var(--border);display:flex;z-index:200;}
.tab{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;color:var(--text3);font-size:9.5px;border:none;background:none;transition:color .2s;position:relative;}
.tab svg{width:21px;height:21px;}
.tab.active{color:var(--accent);}
.tab-dot{position:absolute;top:8px;right:calc(50% - 14px);width:6px;height:6px;border-radius:50%;background:var(--red);display:none;}
.tab-dot.show{display:block;}

/* ── CONTENT ── */
.content{padding:12px 12px calc(var(--tab-h)+12px);min-height:calc(100vh - var(--hd-h));}
.page{display:none;animation:fadeIn .18s ease;}
.page.active{display:block;}
@keyframes fadeIn{from{opacity:.6;transform:translateY(4px)}to{opacity:1;transform:none}}

/* ── CARDS ── */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r2);padding:14px;margin-bottom:10px;}
.card-sm{background:var(--bg3);border-radius:var(--r);padding:11px 13px;}
.card-title{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;font-weight:600;}
.section-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.section-hd h3{font-size:15px;font-weight:700;}
.divider{height:1px;background:var(--border);margin:11px 0;}

/* ── INPUTS ── */
.inp{width:100%;background:var(--bg3);border:1.5px solid var(--border);border-radius:var(--r);padding:10px 13px;color:var(--text);font-family:var(--font);font-size:14px;outline:none;transition:border-color .2s;}
.inp:focus{border-color:var(--accent);}
.inp::placeholder{color:var(--text3);}
textarea.inp{resize:none;line-height:1.6;}

/* ── BUTTONS ── */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;border:none;border-radius:var(--r);cursor:pointer;font-family:var(--font);font-weight:600;transition:opacity .15s,transform .1s;}
.btn:active{opacity:.8;transform:scale(.98);}
.btn-primary{background:var(--accent);color:#fff;padding:12px 18px;font-size:14px;width:100%;}
.btn-success{background:var(--green);color:#0b0f1a;padding:12px 18px;font-size:14px;width:100%;}
.btn-outline{background:transparent;border:1px solid var(--border2);color:var(--text2);padding:7px 13px;font-size:12px;}
.btn-sm{padding:5px 11px;font-size:11px;border-radius:7px;}
.btn-icon{width:38px;height:38px;border-radius:50%;background:var(--accent);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}

/* ── MARKET INDEX ROW ── */
.idx-row{display:flex;gap:7px;overflow-x:auto;padding-bottom:2px;margin-bottom:12px;scrollbar-width:none;}
.idx-row::-webkit-scrollbar{display:none;}
.idx-pill{flex-shrink:0;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:9px 13px;min-width:96px;}
.idx-pill-n{font-size:10px;color:var(--text3);}
.idx-pill-v{font-size:14px;font-weight:700;margin-top:2px;}
.idx-pill-c{font-size:11px;margin-top:1px;}

/* ── STOCK ANALYSIS ── */
.stock-hero{margin-bottom:11px;}
.s-name-row{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;}
.s-name{font-size:21px;font-weight:800;letter-spacing:-.5px;}
.s-sub{font-size:12px;color:var(--text2);margin-top:2px;}
.price-row{display:flex;align-items:baseline;gap:10px;margin-top:8px;}
.price-big{font-size:30px;font-weight:800;letter-spacing:-1px;}
.price-change{font-size:13px;font-weight:700;padding:3px 9px;border-radius:6px;}
.up{color:var(--green);} .down{color:var(--red);}
.up-bg{background:var(--green-dim);color:var(--green);border:1px solid var(--green-border);}
.down-bg{background:var(--red-dim);color:var(--red);border:1px solid var(--red-border);}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.stat-it{background:var(--bg3);border-radius:8px;padding:9px 12px;}
.stat-lbl{font-size:10px;color:var(--text3);margin-bottom:3px;}
.stat-val{font-size:14px;font-weight:700;}
.period-row{display:flex;gap:5px;margin-bottom:9px;}
.prd{font-size:11px;padding:4px 10px;border:1px solid var(--border);border-radius:6px;background:none;color:var(--text2);cursor:pointer;}
.prd.active{background:var(--blue-dim);color:var(--blue);border-color:var(--blue-border);}
.chart-wrap{position:relative;height:185px;margin:4px 0;}
.ind-row{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px;}
.ind-badge{font-size:11px;padding:3px 8px;border-radius:5px;border:1px solid var(--border);background:var(--bg3);}
.ind-buy{color:var(--green);border-color:var(--green-border);background:var(--green-dim);}
.ind-sell{color:var(--red);border-color:var(--red-border);background:var(--red-dim);}
.ind-hold{color:var(--gold);border-color:var(--gold-border);background:var(--gold-dim);}
.signal-wrap{margin-top:10px;}
.signal-row{display:flex;align-items:center;gap:8px;}
.sig-lbl{font-size:11px;color:var(--text3);min-width:18px;}
.sig-bar{flex:1;height:7px;border-radius:4px;background:var(--bg4);overflow:hidden;}
.sig-fill{height:100%;border-radius:4px;transition:width .5s ease;}
.sig-pct{font-size:11px;color:var(--text2);min-width:30px;text-align:right;}

/* ── AI BOX ── */
.ai-box{background:var(--bg3);border:1px solid var(--green-border);border-radius:var(--r);padding:13px;margin-top:8px;}
.ai-hd{display:flex;align-items:center;gap:7px;font-size:11px;color:var(--text2);margin-bottom:9px;}
.ai-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:aiPulse 2s infinite;}
@keyframes aiPulse{0%,100%{opacity:1}50%{opacity:.3}}
.ai-text{font-size:13px;line-height:1.75;color:var(--text);white-space:pre-wrap;}
.ai-typing{display:flex;gap:4px;padding:6px 0;}
.ai-typing span{width:7px;height:7px;border-radius:50%;background:var(--accent);animation:bounce 1.3s infinite;}
.ai-typing span:nth-child(2){animation-delay:.2s;}
.ai-typing span:nth-child(3){animation-delay:.4s;}
@keyframes bounce{0%,80%,100%{transform:scale(.7);opacity:.5}40%{transform:scale(1);opacity:1}}

/* ── WATCHLIST ── */
.wl-item{display:flex;align-items:center;justify-content:space-between;padding:11px 0;border-bottom:1px solid var(--border);}
.wl-item:last-child{border-bottom:none;}
.wl-l{display:flex;flex-direction:column;gap:2px;}
.wl-code{font-size:14px;font-weight:700;}
.wl-nm{font-size:11px;color:var(--text2);}
.wl-r{display:flex;align-items:center;gap:10px;}
.wl-price{font-size:15px;font-weight:700;text-align:right;}
.wl-chg{font-size:11px;text-align:right;margin-top:1px;}
.wl-del{background:none;border:none;color:var(--text3);font-size:17px;padding:3px 5px;cursor:pointer;}
.sum-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:10px;}
.sum-it{background:var(--bg3);border-radius:8px;padding:9px 12px;text-align:center;}
.sum-v{font-size:18px;font-weight:800;} .sum-l{font-size:10px;color:var(--text3);margin-top:2px;}

/* ── NEWS ── */
.news-it{padding:12px 0;border-bottom:1px solid var(--border);cursor:pointer;}
.news-it:last-child{border-bottom:none;}
.news-tags{display:flex;gap:5px;align-items:center;margin-bottom:5px;}
.ntag{font-size:10px;padding:2px 6px;border-radius:4px;background:var(--blue-dim);color:var(--blue);font-weight:600;}
.nsentiment{font-size:10px;padding:2px 6px;border-radius:4px;font-weight:600;}
.news-title{font-size:13px;line-height:1.55;margin-bottom:4px;}
.news-meta{font-size:10px;color:var(--text3);display:flex;gap:8px;}

/* ── READER ── */
.mode-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:12px;}
.mode-card{background:var(--bg3);border:1.5px solid var(--border);border-radius:var(--r);padding:12px 8px;text-align:center;cursor:pointer;transition:all .2s;}
.mode-card.active{background:var(--blue-dim);border-color:var(--blue-border);}
.mode-card .mc-icon{font-size:20px;margin-bottom:4px;}
.mode-card .mc-lbl{font-size:12px;font-weight:600;}
.mode-card .mc-sub{font-size:10px;color:var(--text3);margin-top:2px;}
.mode-card.active .mc-sub{color:var(--blue);}
.upload-zone{width:100%;min-height:110px;background:var(--bg3);border:2px dashed var(--border2);border-radius:var(--r);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;cursor:pointer;padding:18px;}
.upload-zone.drag{border-color:var(--accent);}
.uz-icon{font-size:28px;}
.uz-txt{font-size:12px;color:var(--text2);text-align:center;}
.uz-sub{font-size:10px;color:var(--text3);}
.img-prev{width:100%;border-radius:var(--r);border:1px solid var(--border);margin-top:7px;max-height:180px;object-fit:cover;}
.focus-row{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px;}
.ftag{font-size:11px;padding:5px 10px;border-radius:16px;border:1px solid var(--border);background:var(--bg3);color:var(--text2);cursor:pointer;}
.ftag.active{background:var(--bg);color:var(--text);border-color:var(--border2);}
.prog-bar{width:100%;height:3px;background:var(--bg3);border-radius:2px;overflow:hidden;margin-top:7px;}
.prog-fill{height:100%;background:var(--accent);border-radius:2px;width:0%;transition:width .3s;}
.step-lbl{font-size:10px;color:var(--text3);text-align:center;margin-top:5px;}

/* ── READER RESULTS ── */
.sig-card{border-radius:var(--r);padding:14px;margin-bottom:9px;border:1.5px solid;}
.sig-card.buy{background:var(--green-dim);border-color:var(--green-border);}
.sig-card.sell{background:var(--red-dim);border-color:var(--red-border);}
.sig-card.watch{background:var(--gold-dim);border-color:var(--gold-border);}
.sig-card.neutral{background:var(--blue-dim);border-color:var(--blue-border);}
.sig-hd{display:flex;align-items:center;gap:9px;margin-bottom:11px;flex-wrap:wrap;}
.sig-badge{font-size:12px;font-weight:700;padding:4px 11px;border-radius:18px;flex-shrink:0;}
.buy .sig-badge{background:var(--green);color:#0b0f1a;}
.sell .sig-badge{background:var(--red);color:#fff;}
.watch .sig-badge{background:var(--gold);color:#0b0f1a;}
.neutral .sig-badge{background:var(--blue);color:#fff;}
.sig-title{font-size:14px;font-weight:700;flex:1;}
.sig-conf{font-size:10px;color:var(--text3);margin-left:auto;}
.kn-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.kn-it{background:rgba(0,0,0,.2);border-radius:8px;padding:9px 11px;border-left:3px solid var(--accent);}
.kn-lbl{font-size:10px;color:var(--text3);margin-bottom:3px;}
.kn-val{font-size:14px;font-weight:700;}
.hl-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:9px;}
.hl-title{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:11px;display:flex;align-items:center;gap:6px;}
.hl-it{display:flex;gap:9px;padding:8px 0;border-bottom:1px solid var(--border);align-items:flex-start;}
.hl-it:last-child{border-bottom:none;}
.hl-tag{flex-shrink:0;font-size:9px;font-weight:700;padding:2px 6px;border-radius:4px;margin-top:2px;letter-spacing:.3px;}
.hl-tag.positive{background:var(--green);color:#0b0f1a;}
.hl-tag.negative{background:var(--red);color:#fff;}
.hl-tag.neutral{background:var(--gold);color:#0b0f1a;}
.hl-tag.data{background:var(--blue);color:#fff;}
.hl-text{font-size:12px;line-height:1.65;color:var(--text);}
.hl-text mark{background:rgba(245,200,66,.2);color:var(--gold);border-radius:3px;padding:0 2px;}
.rpt-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:var(--r);padding:14px;margin-bottom:9px;}
.rpt-sec{margin-bottom:13px;}
.rpt-sec:last-child{margin-bottom:0;}
.rpt-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.7px;color:var(--accent);font-weight:700;margin-bottom:6px;padding-bottom:5px;border-bottom:1px solid var(--border);}
.rpt-txt{font-size:12px;line-height:1.75;color:var(--text2);}

/* ── CHAT ── */
.chat-hist{display:flex;flex-direction:column;gap:9px;max-height:340px;overflow-y:auto;margin-bottom:10px;padding-right:2px;}
.chat-hist::-webkit-scrollbar{width:3px;}
.chat-hist::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.bubble{max-width:86%;padding:9px 13px;border-radius:14px;font-size:13px;line-height:1.65;white-space:pre-wrap;}
.bubble-u{background:var(--blue-dim);border:1px solid var(--blue-border);color:var(--text);align-self:flex-end;border-bottom-right-radius:4px;}
.bubble-a{background:var(--bg3);border:1px solid var(--border);color:var(--text);align-self:flex-start;border-bottom-left-radius:4px;}
.chat-inp-row{display:flex;gap:8px;align-items:flex-end;}
.chat-inp{flex:1;background:var(--bg3);border:1.5px solid var(--border);border-radius:12px;padding:10px 13px;color:var(--text);font-size:13px;resize:none;outline:none;min-height:40px;max-height:110px;font-family:var(--font);line-height:1.5;}
.chat-inp:focus{border-color:var(--accent);}
.qtag{font-size:11px;padding:5px 11px;border:1px solid var(--border);border-radius:14px;background:var(--bg3);color:var(--text2);cursor:pointer;white-space:nowrap;}

/* ── SETTINGS ── */
.sett-row{display:flex;align-items:center;justify-content:space-between;padding:12px 0;border-bottom:1px solid var(--border);}
.sett-row:last-child{border-bottom:none;}
.sett-lbl{font-size:14px;} .sett-sub{font-size:11px;color:var(--text3);margin-top:2px;}
.toggle{width:42px;height:25px;border-radius:13px;background:var(--border2);position:relative;cursor:pointer;transition:background .2s;border:none;flex-shrink:0;}
.toggle.on{background:var(--green);}
.toggle::after{content:'';position:absolute;width:19px;height:19px;border-radius:50%;background:#fff;top:3px;left:3px;transition:left .2s;}
.toggle.on::after{left:20px;}

/* ── HISTORY PAGE ── */
.hist-it{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:12px;margin-bottom:8px;cursor:pointer;transition:border-color .2s;}
.hist-it:active{border-color:var(--accent);}
.hist-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.hist-type{font-size:10px;padding:2px 7px;border-radius:4px;background:var(--bg4);color:var(--text2);}
.hist-time{font-size:10px;color:var(--text3);}
.hist-ttl{font-size:13px;font-weight:600;margin-bottom:3px;}
.hist-prv{font-size:11px;color:var(--text3);line-height:1.5;}
.hist-sig{font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;display:inline-block;margin-top:5px;}
.empty{text-align:center;padding:40px 20px;color:var(--text3);}
.empty .ei{font-size:34px;margin-bottom:10px;}

/* ── MISC ── */
.info-note{font-size:11px;color:var(--text3);line-height:1.6;margin-top:6px;}
.tag-scroll{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;margin-bottom:12px;}
.tag-scroll::-webkit-scrollbar{display:none;}
</style>
</head>
<body>

<div class="hd">
  <div class="hd-left">
    <div class="hd-logo">📊</div>
    <div>
      <div class="hd-name">台股 AI 助理</div>
      <div class="hd-sub">分析 · 研讀 · 追蹤 · 對話</div>
    </div>
  </div>
  <div class="mkt-badge" id="mktBadge" style="background:var(--green-dim);color:var(--green);border-color:var(--green-border)">開盤中</div>
</div>

<div class="content">

<!-- ════════════════════════════
     PAGE 1 — 股票分析
════════════════════════════ -->
<div class="page active" id="page-analyze">
  <div class="idx-row">
    <div class="idx-pill"><div class="idx-pill-n">加權指數</div><div class="idx-pill-v">22,485</div><div class="idx-pill-c up">▲ +1.23%</div></div>
    <div class="idx-pill"><div class="idx-pill-n">電子類</div><div class="idx-pill-v">1,042</div><div class="idx-pill-c up">▲ +0.87%</div></div>
    <div class="idx-pill"><div class="idx-pill-n">金融類</div><div class="idx-pill-v">2,184</div><div class="idx-pill-c down">▼ -0.34%</div></div>
    <div class="idx-pill"><div class="idx-pill-n">USD/NTD</div><div class="idx-pill-v">32.18</div><div class="idx-pill-c down">▼ -0.06%</div></div>
    <div class="idx-pill"><div class="idx-pill-n">外資</div><div class="idx-pill-v">+82億</div><div class="idx-pill-c up">買超</div></div>
  </div>

  <div style="display:flex;gap:7px;margin-bottom:8px;">
    <input class="inp" id="stockInput" placeholder="輸入股票代號，例如 2330" inputmode="numeric" maxlength="6" style="flex:1" onkeydown="if(event.key==='Enter')lookupStock()">
    <button class="btn btn-primary" style="width:auto;padding:0 18px" onclick="lookupStock()">查詢</button>
  </div>
  <div class="tag-scroll">
    <span class="qtag" onclick="quickS('2330')">2330 台積電</span>
    <span class="qtag" onclick="quickS('2317')">2317 鴻海</span>
    <span class="qtag" onclick="quickS('2454')">2454 聯發科</span>
    <span class="qtag" onclick="quickS('2382')">2382 廣達</span>
    <span class="qtag" onclick="quickS('0050')">0050 元大50</span>
  </div>

  <div id="analyzeWelcome" class="empty"><div class="ei">🔍</div><p>輸入股票代號<br>開始 AI 技術分析</p></div>
  <div id="analyzeResult" style="display:none"></div>
</div>

<!-- ════════════════════════════
     PAGE 2 — 智能研讀
